# ==============================================================================
# InsightFlow Environment Variables Template (.env.example)
# Copy this file to .env and fill in the values.
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend Configuration
# ------------------------------------------------------------------------------
# API Key for Groq Llama models (required for natural language to pandas translation)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Shared secret key between the frontend SSR server and backend FastAPI middleware
INTERNAL_API_SECRET=your_super_secret_internal_secret_here

# Comma-separated list of allowed CORS origins for FastAPI backend
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Background session cleanup interval in seconds
SESSION_CLEANUP_INTERVAL_SECONDS=300

# Data session Time-to-Live in minutes
SESSION_TTL_MINUTES=30

# ------------------------------------------------------------------------------
# Frontend & SSR Server Configuration
# ------------------------------------------------------------------------------
# FastAPI Backend URL (accessed from within Docker network, or locally)
MODELING_API_URL=http://localhost:8000

# Supabase configuration details (required for authentication)
SUPABASE_URL=https://your_supabase_project_ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_key

# ------------------------------------------------------------------------------
# Optional AI Provider Integrations
# ------------------------------------------------------------------------------
# OpenAI or custom OpenAI-compatible endpoint key/endpoints (used for code reviews or analysis)
OPENAI_API_KEY=sk-proj-your_openai_key_here
AI_API_KEY=your_generic_ai_api_key_here
AI_API_ENDPOINT=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini

# Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# Testing & E2E Verification
# ------------------------------------------------------------------------------
# Enable mock authentication bypass for automated testing (set to 1 to enable)
E2E_AUTH_BYPASS=0
